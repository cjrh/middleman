{
  "name": "middleman-frontend",
  "version": "0.1.0",
  "private": true,
  "license": "Elastic-2.0",
  "type": "module",
  "scripts": {
    "dev": "node ../node_modules/vite-plus/bin/vp dev",
    "build": "node ../node_modules/vite-plus/bin/vp build --logLevel warn",
    "preview": "node ../node_modules/vite-plus/bin/vp preview",
    "check": "cd .. && node node_modules/vite-plus/bin/vp run frontend-package-check",
    "lint": "node ../node_modules/vite-plus/bin/vp lint . --no-error-on-unmatched-pattern",
    "lint:fix": "node ../node_modules/vite-plus/bin/vp lint . --fix --no-error-on-unmatched-pattern",
    "typecheck": "cd .. && node node_modules/vite-plus/bin/vp run frontend-package-typecheck",
    "test": "node ../node_modules/vite-plus/bin/vp test run --project unit",
    "test:browser": "node ../node_modules/vite-plus/bin/vp test run --project browser",
    "test:e2e": "node ./scripts/run-e2e-to-file.ts",
    "test:e2e:mock": "node ../node_modules/vite-plus/bin/vp exec -- playwright test --config=playwright.config.ts",
    "demo-workspace": "node node_modules/.bin/playwright test --config tests/demo/playwright-demo.config.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lucide/svelte": "1.21.0",
    "@middleman/ui": "workspace:*",
    "@pierre/diffs": "1.2.11",
    "@pierre/trees": "1.0.0-beta.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "3.4.11",
    "ghostty-web": "^0.4.0",
    "js-toml": "^1.0.3",
    "marked": "18.0.5",
    "mermaid": "11.15.0",
    "openapi-fetch": "^0.17.0",
    "simple-icons": "^16.19.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@testing-library/svelte": "5.4.0",
    "@tsconfig/svelte": "5.0.8",
    "@types/node": "^26.0.0",
    "@vitest/browser-playwright": "4.1.9",
    "jsdom": "29.1.1",
    "openapi-typescript": "^7.13.0",
    "playwright": "1.61.0",
    "svelte": "5.56.3",
    "vite": "8.0.16",
    "vite-plus": "0.2.1",
    "vitest": "4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.0.0",
      "onFail": "download"
    }
  },
  "packageManager": "bun@1.3.11"
}
