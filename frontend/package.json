{
  "name": "middleman-frontend",
  "version": "0.1.0",
  "private": true,
  "license": "Elastic-2.0",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build --logLevel warn",
    "preview": "vp preview",
    "check": "vp check --no-error-on-unmatched-pattern && vp run -w svelte-check:frontend",
    "lint": "vp lint . --no-error-on-unmatched-pattern",
    "lint:fix": "vp lint . --fix --no-error-on-unmatched-pattern",
    "typecheck": "vp check --no-fmt --no-lint --no-error-on-unmatched-pattern && vp run -w svelte-check:frontend",
    "test": "vp test run",
    "test:e2e": "bun ./scripts/run-e2e-to-file.ts",
    "test:e2e:mock": "playwright test --config=playwright.config.ts",
    "demo-workspace": "playwright test --config tests/demo/playwright-demo.config.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lucide/svelte": "1.3.0",
    "@middleman/ui": "workspace:*",
    "@pierre/trees": "1.0.0-beta.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "3.4.0",
    "ghostty-web": "^0.4.0",
    "js-toml": "^1.0.3",
    "marked": "17.0.5",
    "openapi-fetch": "^0.17.0",
    "simple-icons": "^16.19.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@testing-library/svelte": "5.2.8",
    "@tsconfig/svelte": "5.0.8",
    "@types/dompurify": "3.2.0",
    "@types/node": "^24.9.2",
    "jsdom": "26.1.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "1.60.0",
    "svelte": "5.55.0",
    "svelte-check": "4.4.5",
    "vite": "8.0.5",
    "vite-plus": "0.1.22"
  },
  "packageManager": "bun@1.3.11"
}
