{
  "name": "@middleman/ui",
  "version": "0.0.1",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "svelte": "src/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./api/types": {
      "default": "./src/api/types.ts"
    },
    "./api/client": {
      "default": "./src/api/generated/client.ts"
    },
    "./api/schema": {
