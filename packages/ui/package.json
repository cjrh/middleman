  "scripts": {
    "check": "cd ../.. && vp check packages/ui '!packages/ui/src/api/generated/**' '!packages/ui/src/api/roborev/generated/**' --no-error-on-unmatched-pattern && vp run -w svelte-check:ui",
    "lint": "cd ../.. && vp lint packages/ui --no-error-on-unmatched-pattern",
    "typecheck": "cd ../.. && vp check packages/ui '!packages/ui/src/api/generated/**' '!packages/ui/src/api/roborev/generated/**' --no-fmt --no-lint --no-error-on-unmatched-pattern && vp run -w svelte-check:ui"
