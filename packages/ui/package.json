    "prosemirror-state": "^1.4.4",
    "svelte-tiptap": "3.0.1"
  },
  "devDependencies": {
    "@testing-library/svelte": "5.2.8",
    "@tsconfig/svelte": "^5.0.0",
    "@types/dompurify": "3.2.0",
    "@types/node": "^24.9.2",
    "openapi-fetch": "^0.17.0",
    "svelte": "^5.55.0",
    "svelte-check": "4.4.5",
    "vite-plus": "0.1.22"
