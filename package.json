{
  "private": true,
  "license": "Elastic-2.0",
  "workspaces": [
    "frontend",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "node node_modules/vite-plus/bin/vp run frontend-check",
    "demo-workspace": "node node_modules/vite-plus/bin/vp run middleman-frontend#demo-workspace",
    "fmt": "node node_modules/vite-plus/bin/vp fmt frontend packages/ui --no-error-on-unmatched-pattern --threads=1",
    "fmt:check": "node node_modules/vite-plus/bin/vp fmt --check frontend packages/ui --no-error-on-unmatched-pattern --threads=1",
    "test:e2e": "node node_modules/vite-plus/bin/vp run middleman-frontend#test:e2e"
  },
  "devDependencies": {
    "svelte-check": "4.6.0",
    "vite-plus": "0.1.24"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.0.0",
      "onFail": "download"
    }
  },
  "packageManager": "bun@1.3.14"
}
